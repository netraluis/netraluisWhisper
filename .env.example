# Copy to .env and fill in. .env is gitignored.

# Which speech-to-text provider to use: groq | openai
STT_PROVIDER=groq

# Provide the key for whichever provider you picked:
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional overrides:
# GROQ_MODEL=whisper-large-v3-turbo
# OPENAI_MODEL=whisper-1           # or gpt-4o-transcribe
# STT_LANG=es
# TRIGGER_KEYCODE=3676             # Right Cmd. Run `npm run keys` to find yours.
