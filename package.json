{
  "name": "netraluiswhisper",
  "version": "0.1.0",
  "description": "Local push-to-talk voice dictation for macOS (Wispr Flow style).",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npm run build:infer",
    "build:infer": "esbuild infer-web/infer.src.js --bundle --format=esm --outfile=infer-web/infer.js && node scripts/copy-ort-wasm.mjs",
    "start": "npm run build && electron .",
    "keys": "DEBUG_KEYS=1 npm run start",
    "spike": "tsc && electron dist/spike.js",
    "dist": "npm run build && electron-builder --mac"
  },
  "license": "MIT",
  "build": {
    "appId": "com.netraluis.netraluiswhisper",
    "productName": "netraluisWhisper",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "web/**/*",
      "renderer/**/*",
      "infer-web/**/*",
      "package.json",
      "!**/*.map",
      "!.env",
      "!.env.*"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null,
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "netraluisWhisper necesita el micrófono para transcribir tu voz.",
        "NSAppleEventsUsageDescription": "netraluisWhisper usa Apple Events para pegar el texto transcrito en la app activa."
      }
    },
    "dmg": {
      "artifactName": "${productName}.${ext}"
    }
  },
  "devDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@types/express": "^4.17.25",
    "@types/node": "^22.10.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.22.2",
    "uiohook-napi": "^1.5.4"
  }
}
